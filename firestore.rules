rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ajithsabzz@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidListing(data) {
      return data.keys().hasAll(['title', 'price', 'type', 'city', 'ownerId']) &&
             data.title is string && data.title.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.type in ['APARTMENT', 'ROOM', 'STUDIO'];
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['listingId', 'userId', 'moveInDate', 'totalRent', 'status']) &&
             data.listingId is string &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // User Profiles
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdmin();
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReservation(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
