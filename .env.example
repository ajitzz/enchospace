# Neon Database Connection
DATABASE_URL=

# Upstash Redis Connection
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe Keys
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Gemini API Key (Handled by platform, but for local testing)
GEMINI_API_KEY=

# Comma-separated CORS allowlist for API server (e.g. https://enchospace.vercel.app,https://www.enchospace.com)
ALLOWED_ORIGINS=

# Optional frontend override for API base URL in production (e.g. https://api.enchospace.com)
VITE_API_BASE_URL=
